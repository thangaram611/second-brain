{
  "name": "@second-brain/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "brain": "./dist/index.mjs"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts",
