# Pin the Node runtime pnpm uses for install scripts and `pnpm exec`/`pnpm run`
# so native bindings (better-sqlite3, keytar, argon2) are always prebuilt
# against the same Node ABI that `brain`, `codex`, `cursor`, etc. spawn at
# runtime. Without this, pnpm picks up whatever `node` is first on PATH —
# typically homebrew Node on macOS, which can be a newer major than nvm's
# active version and produces ABI-mismatched prebuilds.
#
# Must match `.nvmrc`. Bump both together.
use-node-version=22.21.1

# Refuse to install when the running Node is outside the package.json
# `engines` band. Belt-and-braces with use-node-version: if pnpm itself
# is invoked under an unsupported Node before this config is loaded,
# fail loudly instead of producing a broken install.
engine-strict=true
