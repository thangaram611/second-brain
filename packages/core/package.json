    "drizzle-orm": "^0.45.0",
    "sqlite-vec": "^0.1.9",
    "ulidx": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.0",
    "tsdown": "^0.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
