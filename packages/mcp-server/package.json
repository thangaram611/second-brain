{
  "name": "@second-brain/mcp-server",
  "version": "0.1.0",
  "description": "MCP server exposing the second-brain knowledge graph to LLM clients (Claude Code, etc.).",
  "private": true,
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "second-brain-mcp": "./dist/stdio.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "knowledge-graph",
    "second-brain"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts src/stdio.ts src/http.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@second-brain/core": "workspace:*",
    "@second-brain/ingestion": "workspace:*",
    "@second-brain/types": "workspace:*",
    "express": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "tsdown": "^0.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
