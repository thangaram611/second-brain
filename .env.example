# Second Brain Configuration

# LLM Provider (ollama | anthropic | openai | groq)
BRAIN_LLM_PROVIDER=ollama
BRAIN_LLM_MODEL=llama3.2
BRAIN_EMBEDDING_MODEL=nomic-embed-text
BRAIN_LLM_BASE_URL=http://localhost:11434
# BRAIN_LLM_API_KEY=

# Server
# REST API port (apps/server). MCP HTTP server defaults to BRAIN_MCP_PORT=7420.
BRAIN_API_PORT=7430

# UI dev server runs on Vite's default port 5173 (not env-configurable).

# Relay (for project brain sync)
RELAY_PORT=7421
# RELAY_AUTH_SECRET=

# GitHub Integration
# GITHUB_TOKEN=ghp_...
