{
  "name": "@second-brain/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./services/users": {
      "types": "./src/services/users.ts",
      "import": "./src/services/users.ts"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@second-brain/collectors": "workspace:*",
    "@second-brain/core": "workspace:*",
    "@second-brain/ingestion": "workspace:*",
    "@second-brain/mcp-server": "workspace:*",
    "@second-brain/sync": "workspace:*",
    "@second-brain/types": "workspace:*",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.0.0",
    "express": "^5.1.0",
    "picomatch": "^4.0.4",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.2",
    "@types/picomatch": "^3.0.2",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.0",
    "supertest": "^7.1.0",
    "tsdown": "^0.21.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
